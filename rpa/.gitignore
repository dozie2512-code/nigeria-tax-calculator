# Ignore installed packages and generated artifacts
node_modules/
artifacts/

# Ignore real credentials / selectors with real data
.env
filing.json
selectors.taxpromax.json

# Playwright browser binaries cache
.playwright/

# Playwright auth / storage-state files (contain session cookies — never commit)
*.auth.json
*.storageState.json
storageState.json
auth-state.json
