{
  "name": "taxpromax-rpa",
  "version": "1.0.0",
  "description": "TaxProMax CIT RPA runner using Playwright (review + submit modes)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "rpa": "node run.js",
    "rpa:review": "cross-env RPA_MODE=review node run.js",
    "rpa:submit": "cross-env RPA_MODE=submit node run.js",
    "transform": "node transform.js",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.55.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5"
  }
}
