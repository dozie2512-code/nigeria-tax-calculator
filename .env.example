# ─────────────────────────────────────────────────────────────────────────────
#  TaxProMax RPA — Environment Variables
#
#  Copy this file to rpa/.env and fill in real values.
#  NEVER commit rpa/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
TAXPROMAX_EMAIL=your_email@example.com
TAXPROMAX_PASSWORD=your_password_here

# ── Portal URLs (defaults shown; change only if the portal moves) ─────────────
TAXPROMAX_BASE_URL=https://taxpromax.firs.gov.ng
TAXPROMAX_LOGIN_URL=https://taxpromax.firs.gov.ng/taxpayer/logincit
TAXPROMAX_PENDING_URL=https://taxpromax.firs.gov.ng/taxpayer/pending

# Override to jump directly to a specific schedule page (skips clicking Process)
# TAXPROMAX_SCHEDULE_URL=https://taxpromax.firs.gov.ng/taxpayer/sch26?id=21302371

# ── RPA behaviour ─────────────────────────────────────────────────────────────
# "review"  — default; stops before final submission, saves screenshots + log
# "submit"  — fills AND submits; use only after reviewing output in review mode
RPA_MODE=review

# ── File paths (relative to rpa/ directory) ───────────────────────────────────
# Path to the CIT filing payload (edit rpa/filing.sample.json and point here)
FILING_JSON=./filing.sample.json

# Path to the selector map (copy selectors.taxpromax.example.json, fill in real
# selectors, and point here once done)
SELECTORS_FILE=./selectors.taxpromax.example.json

# ── Browser options ───────────────────────────────────────────────────────────
# Run with a visible browser window (false = show browser; true = headless/CI)
HEADLESS=false

# Slow-motion delay in milliseconds between actions (useful for debugging)
SLOW_MO=80
