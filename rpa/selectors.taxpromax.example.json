{
  "_doc": {
    "about": "TaxProMax selector map. Copy this file to selectors.taxpromax.json and fill in the real selectors.",
    "howToObtainSelectors": [
      "1. Open TaxProMax in Chrome/Edge DevTools (F12).",
      "2. Click the 'Elements' tab and use the Inspect (Ctrl+Shift+C) tool to click a field.",
      "3. Note the element's `id`, `name`, or a stable CSS attribute.",
      "4. Prefer: `#id` over `[name=...]` over `text=Label` over XPath.",
      "5. Replace the placeholder strings below (e.g. 'REPLACE_ME') with real selectors.",
      "6. Never commit credentials; only commit this selectors file if it contains no sensitive data."
    ],
    "selectorFormats": {
      "byId": "#elementId",
      "byName": "[name='fieldName']",
      "byLabel": "label:has-text('Label Text') + input",
      "byText": "text=Button Text",
      "byClass": ".css-class-name",
      "byXPath": "xpath=//input[@placeholder='Amount']"
    }
  },

  "login": {
    "_doc": "Selectors for https://taxpromax.firs.gov.ng/taxpayer/logincit",
    "emailField":    "#email",
    "passwordField": "#password",
    "submitButton":  "button[type='submit']",
    "errorSelector": ".alert-danger, .error-message, [class*='error']"
  },

  "pending": {
    "_doc": "Selectors for https://taxpromax.firs.gov.ng/taxpayer/pending — the Pending filings list.",
    "filingRow":     "tr, .filing-row, [class*='row']",
    "processButton": "text=Process, button:has-text('Process'), a:has-text('Process')"
  },

  "schedule": {
    "_doc": "Selectors for the CIT Schedule page (e.g. /taxpayer/sch26?id=...). Replace all REPLACE_ME values.",
    "statusSelect": "REPLACE_ME — e.g. select#scheduleStatus or [name='status']",

    "fields": {
      "_doc": "Map of filing.amounts keys → CSS selector for the corresponding input on the schedule page.",
      "revenue":                  "REPLACE_ME — e.g. #revenue or [name='revenue'] or input[placeholder*='Revenue']",
      "nonCurrentAssets":         "REPLACE_ME — e.g. #nonCurrentAssets or [name='nonCurrentAssets']",
      "currentAsset":             "REPLACE_ME — e.g. #currentAsset or [name='currentAsset']",
      "costOfSales":              "REPLACE_ME — e.g. #costOfSales or [name='costOfSales']",
      "otherIncome":              "REPLACE_ME — e.g. #otherIncome or [name='otherIncome']",
      "operatingExpenses":        "REPLACE_ME — e.g. #operatingExpenses or [name='operatingExpenses']",
      "currentLiabilities":       "REPLACE_ME — e.g. #currentLiabilities or [name='currentLiabilities']",
      "longTermLiabilities":      "REPLACE_ME — e.g. #longTermLiabilities or [name='longTermLiabilities']",
      "ownershipCapitalStructure":"REPLACE_ME — e.g. #ownershipCapitalStructure or [name='ownershipCapitalStructure']",
      "reserve":                  "REPLACE_ME — e.g. #reserve or [name='reserve']",
      "profitAdjustment":         "REPLACE_ME — e.g. #profitAdjustment or [name='profitAdjustment']",
      "balancingAdjustment":      "REPLACE_ME — e.g. #balancingAdjustment or [name='balancingAdjustment']",
      "lossRelieved":             "REPLACE_ME — e.g. #lossRelieved or [name='lossRelieved']",
      "capitalAllowance":         "REPLACE_ME — e.g. #capitalAllowance or [name='capitalAllowance']"
    },

    "saveButton":             "REPLACE_ME — e.g. button:has-text('Save') or button[type='submit']",
    "submitButton":           "REPLACE_ME — e.g. button:has-text('Submit') or button:has-text('Transmit')",
    "confirmationSelector":   "REPLACE_ME — e.g. .confirmation-message or [class*='success']"
  }
}
